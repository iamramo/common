{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": "allow",
    "webfetch": "allow",
    "websearch": "ask",
    "todowrite": "allow",
    "todoread": "allow"
  },
  "mcp": {
    "skapa-design-system": {
      "type": "local",
      "command": ["npx", "@ingka/skapa-design-system-mcp"],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false
    },
    "portainer": {
      "type": "local",
      "command": [
        "/usr/local/bin/portainer-mcp",
        "-server",
        "portainer.arpa",
        "-token",
        "{env:PORTAINER_TOKEN}",
        "-disable-version-check"
      ],
      "enabled": false
    },
    "azure": {
      "type": "local",
      "command": ["npx", "-y", "@azure/mcp@latest", "server", "start"],
      "enabled": false
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/ramo"
      ],
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    },
    "affine_workspace": {
      "type": "remote",
      "url": "https://affine.arpa/api/workspaces/c4f634bd-c220-4bfb-807f-3b59a9424317/mcp",
      "headers": {
        "Authorization": "Bearer {env:AFFINE_WORKSPACE_AUTH_TOKEN}"
      },
      "oauth": false,
      "enabled": false
    }
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://litellm.arpa/v1"
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6"
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5"
        },
        "xai/grok-4": {
          "name": "Grok 4"
        },
        "gemini/gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro"
        },
        "gemini/gemini-3-flash-preview": {
          "name": "Gemini 3 Flash"
        }
      }
    }
  }
}

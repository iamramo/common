{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": "ask",
    "cat": "allow",
    "ls": "allow",
    "find": "allow",
    "sort": "allow",
    "grep": "allow",
    "echo": "allow",
    "glob": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "ask",
    "todowrite": "allow",
    "todoread": "allow"
  },
  "mcp": {
    "skapa-design-system": {
      "type": "local",
      "command": ["npx", "@ingka/skapa-design-system-mcp"],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false
    }
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://litellm.arpa/v1"
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6"
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5"
        },
        "xai/grok-4": {
          "name": "Grok 4"
        },
        "gemini/gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro"
        },
        "gemini/gemini-3-flash-preview": {
          "name": "Gemini 3 Flash"
        }
      }
    }
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": "allow",
    "webfetch": "allow",
    "websearch": "ask",
    "todowrite": "allow",
    "todoread": "allow"
  },
  "mcp": {
    "skapa-design-system": {
      "type": "local",
      "command": ["npx", "@ingka/skapa-design-system-mcp"],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false
    },
    "portainer": {
      "type": "local",
      "command": [
        "/usr/local/bin/portainer-mcp",
        "-server",
        "portainer.arpa",
        "-token",
        "{env:PORTAINER_TOKEN}",
        "-disable-version-check"
      ],
      "enabled": false
    },
    "azure": {
      "type": "local",
      "command": ["npx", "-y", "@azure/mcp@latest", "server", "start"],
      "enabled": false
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/ramo"
      ],
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://litellm.arpa/mcp/context7",
      "headers": {
        "x-litellm-api-key": "Bearer {env:LITELLM_API_KEY}"
      },
      "enabled": false
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://litellm.arpa/mcp/gh_grep",
      "headers": {
        "x-litellm-api-key": "Bearer {env:LITELLM_API_KEY}"
      },
      "enabled": false
    },
    "affine_workspace": {
      "type": "remote",
      "url": "https://litellm.arpa/mcp/affine_workspace",
      "headers": {
        "x-litellm-api-key": "Bearer {env:LITELLM_API_KEY}"
      },
      "enabled": false
    }
  },
  "provider": {
    "the-llm-server": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "The LLM Server",
      "options": {
        "baseURL": "http://the-llm-server.arpa/v1"
      },
      "models": {
        "qwen3.5:35b": {
          "name": "QWEN 3.5 (35b)",
          "options": {
            "stream": false
          }
        }
      }
    },
    "litellm": {
      "npm": "@ai-sdk/openai",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://litellm.arpa/v1"
      },
      "models": {
        "gpt-5-mini": {
          "name": "GPT 5 mini"
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5"
        },
        "xai/grok-4": {
          "name": "Grok 4"
        },
        "gemini/gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro"
        },
        "gemini/gemini-3-flash-preview": {
          "name": "Gemini 3 Flash"
        }
      }
    }
  }
}
